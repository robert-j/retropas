{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Turbo Pascal and Delphi",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#prototypes"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#support"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "comment": "Flow control",
          "match": "(?i)\\b(abort|assert|break|continue|exit|fail|halt|while|with|do|downto|for|raise|repeat|runerror|until)\\b",
          "name": "keyword.control.turbo"
        },
        {
          "comment": "Reserved keywords",
          "match": "(?i)\\b(and|array|as|asm|begin|case|class|const|constructor|destructor|div|do|downto|else|end|except|finally|for|function|goto|if|implementation|in|inherited|initialization|inline|interface|is|label|library|mod|nil|not|object|of|or|packed|procedure|program|property|raise|record|repeat|set|shl|shr|then|to|try|type|unit|until|uses|var|while|with|xor)\\b",
          "name": "keyword.turbo"
        },
        {
          "comment": "Directives",
          "match": "(?i)\\b(absolute|abstract|assembler|at|cdecl|default|dynamic|export|external|far|forward|interrupt|message|near|nodefault|on|override|private|protected|public|published|resident|stored|virtual)\\b",
          "name": "keyword.turbo"
        },
        {
          "comment": "Additional function-like keywords",
          "name": "keyword.turbo",
          "match": "(?i)\\b(?<!\\.)(low|high|sizeof|typeof)\\s*\\("
        },
        {
          "comment": "Special variables",
          "match": "(?i)\\b(self|result)\\b",
          "name": "variable.language.turbo"
        },
        {
          "comment": "read/write as part of a property",
          "name": "keyword.turbo",
          "match": "(?i)\\b(read|write)\\b\\w+"
        },
        {
          "comment": "index <number>",
          "match": "(?i)\\b(?<!\\.)(index)\\s+([\\d\\$a-f]+)",
          "captures": {
            "1": {
              "name": "keyword.turbo"
            },
            "2": {
              "patterns": [
                {
                  "include": "#numbers"
                }
              ]
            }
          }
        },
        {
          "comment": "name <string>",
          "match": "(?i)\\b(?<!\\.)(name)\\s+('.*?)$",
          "captures": {
            "1": {
              "name": "keyword.turbo"
            },
            "2": {
              "patterns": [
                {
                  "include": "$self"
                }
              ]
            }
          }
        },
        {
          "comment": "Exports",
          "match": "(?i)\\b(?<!\\.)(exports)\\b\\s+(\\w+(\\.\\w+)?)",
          "captures": {
            "1": {
              "name": "keyword.turbo"
            },
            "2": {
              "name": "entity.name.function.turbo"
            }
          }
        }
      ]
    },
    "prototypes": {
      "patterns": [
        {
          "name": "meta.function.turbo",
          "match": "(?i)\\b(function|procedure|constructor|destructor|property|read|write)\\b\\s+(\\w+(\\.\\w+)?)",
          "captures": {
            "1": {
              "name": "storage.type.function.turbo"
            },
            "2": {
              "name": "entity.name.function.turbo"
            }
          }
        }
      ]
    },
    "support": {
      "patterns": [
        {
          "comment": "System unit routines",
          "name": "support.function.turbo",
          "match": "(?i)\\b(?<!\\.)(abs|addr|append|arctan|assign|assigned|blockread|blockwrite|chdir|chr|close|concat|copy|cos|cseg|dec|delete|dispose|dseg|eof|eoln|erase|exclude|exp|extended|filepos|filesize|fillchar|flush|frac|freemem|getdir|getmem|hi|high|inc|include|insert|int|ioresult|length|ln|lo|low|maxavail|mem|memavail|meml|memw|mkdir|move|new|odd|ofs|ord|paramcount|paramstr|pi|pos|pred|ptr|random|randomize|read|readln|rename|reset|rewrite|rmdir|round|runerror|seek|seekeof|seekeoln|seg|settextbuf|sin|sptr|sqr|sqrt|sseg|str|succ|swap|trunc|truncate|upcase|val|write|writeln)\\s*\\("
        },
        {
          "comment": "System unit routines w/out arguments, so we cannot match tham with a trailing '('",
          "name": "support.function.turbo",
          "match": "(?i)\\b(?<!\\.)(cseg|dseg|ioresult|maxavail|memavail|paramcount|randomize|sptr|sseg)\\b"
        },
        {
          "comment": "Special Mem* arrays",
          "name": "support.function.turbo",
          "match": "(?i)\\b(?<!\\.)(mem|memw|meml)\\s*\\["
        },
        {
          "comment": "System types",
          "name": "entity.name.type.turbo",
          "match": "(?i)\\b(boolean|byte|bytebool|cardinal|char|comp|double|extended|file|integer|longbool|longint|openstring|real|shortint|single|smallint|string|text|word|wordbool)\\b"
        },
        {
          "comment": "Integer types from Bits",
          "name": "entity.name.type.turbo",
          "match": "(?i)\\b(int8|int16|int32|int64|uint8|uint16|uint32|uint64|intptr|uintptr)\\b"
        },
        {
          "comment": "Pointer types from Objects, SysUtils, System, Bits",
          "name": "entity.name.type.turbo",
          "match": "(?i)\\b(pointer|ppointer|pboolean|pbyte|pchar|ppchar|pinteger|plongint|plong|pstring|ppstring|pword)\\b"
        },
        {
          "comment": "System constants",
          "name": "constant.language.turbo",
          "match": "(?i)\\b(true|false|nil|maxint|maxlongint)\\b"
        },
        {
          "comment": "Types from Objects, SysUtils, Bits",
          "name": "entity.name.type.turbo",
          "match": "(?i)\\b(tclass|tdelegate|tdelegaterec|tmethod|tobject|tprocedure|longrec|ptrrec|wordrec)\\b"
        },
        {
          "comment": "Delegate support for Bits",
          "name": "support.function.turbo",
          "match": "(?i)\\b(invokedelegate_\\w+|makedelegate|isdelegate)\\b"
        },
        {
          "comment": "Flow control",
          "name": "keyword.control.turbo",
          "match": "(?i)\\b(haltbool|setjmp|longjmp)\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "begin": "(^[ \\t]+)?(?=//)",
          "end": "(?!\\G)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.whitespace.comment.leading.turbo"
            }
          },
          "patterns": [
            {
              "begin": "//",
              "end": "\\n",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.definition.comment.turbo"
                }
              },
              "name": "comment.line.double-slash.turbo.two"
            }
          ]
        },
        {
          "begin": "\\(\\*",
          "end": "\\*\\)",
          "captures": {
            "0": {
              "name": "punctuation.definition.comment.turbo"
            }
          },
          "name": "comment.block.turbo.one"
        },
        {
          "begin": "\\{(?!\\$)",
          "end": "\\}",
          "captures": {
            "0": {
              "name": "punctuation.definition.comment.turbo"
            }
          },
          "name": "comment.block.turbo.two"
        },
        {
          "name": "string.regexp",
          "begin": "\\{\\$",
          "end": "\\}",
          "captures": {
            "0": {
              "name": "string.regexp"
            }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "begin": "'",
          "end": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.turbo"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.turbo"
            }
          },
          "name": "string.quoted.single.turbo",
          "patterns": [
            {
              "match": "''",
              "name": "constant.character.escape.apostrophe.turbo"
            }
          ]
        },
        {
          "name": "string.regexp.turbo",
          "match": "#\\d{1,3}\\b"
        },
        {
          "name": "string.regexp.turbo",
          "match": "#\\$[0-9a-fA-F]{1,2}\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "(?i)((?<!\\w)((\\$([0-9a-f])+)|(\\b(([0-9]+\\.?[0-9]*)|(\\.[0-9]+)))(e[\\-+]?\\d+)?))\\b",
          "captures": {
            "1": {
              "name": "constant.numeric.turbo"
            }
          }
        }
      ]
    }
  },
  "scopeName": "source.turbo"
}
